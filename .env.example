# Server-only configuration. Never expose these through NEXT_PUBLIC_* variables.
DATABASE_URL=postgresql://revolution@127.0.0.1:55432/revolution

# Production web origin and database transport. Production must use HTTPS and DB TLS.
MORSE_PUBLIC_ORIGIN=http://127.0.0.1:3010
# Test harness only. Production role launcher rejects true.
MORSE_LOCAL_RELEASE_SMOKE=false
MORSE_DATABASE_SSL_MODE=disable
MORSE_DATABASE_SSL_CA=
MORSE_DATABASE_POOL_MAX=10
MORSE_DATABASE_CONNECT_TIMEOUT_MS=5000
MORSE_DATABASE_IDLE_TIMEOUT_MS=30000
MORSE_DATABASE_STATEMENT_TIMEOUT_MS=30000
MORSE_DATABASE_IDLE_TRANSACTION_TIMEOUT_MS=30000

# OpenAI-compatible GPT access. Select one protocol; requests never auto-fallback.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=
OPENAI_CHAT_PROTOCOL=responses
# Optional compatibility header for gateways that block the OpenAI SDK default User-Agent.
OPENAI_COMPAT_USER_AGENT=

# Optional Embeddings override. Point this at the loopback BGE service when used locally.
OPENAI_EMBEDDING_API_KEY=local-embedding
OPENAI_EMBEDDING_BASE_URL=http://127.0.0.1:18091/v1
OPENAI_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# Explicit local integration-test mode; must stay false in production.
MORSE_ALLOW_TEST_EMBEDDINGS=false

# Access and data lifecycle.
MORSE_ACCESS_COOKIE=morse_access
MORSE_MAX_MESSAGES_PER_SESSION=30
MORSE_SESSION_HOURS=12
MORSE_INTERACTION_RETENTION_DAYS=10
MORSE_MAX_SEARCHES_PER_SESSION=5

# Runtime limits and kill switches.
MORSE_CHAT_ENABLED=true
MORSE_SEARCH_ENABLED=false
MORSE_PROVIDER_CONCURRENCY=4
MORSE_SEARCH_CONCURRENCY=2
MORSE_EMBEDDING_TIMEOUT_MS=8000
MORSE_PROVIDER_FIRST_BYTE_TIMEOUT_MS=20000
MORSE_PROVIDER_TOTAL_TIMEOUT_MS=90000
MORSE_SEARCH_TIMEOUT_MS=12000
MORSE_SSE_HEARTBEAT_MS=15000
MORSE_MAX_OUTPUT_TOKENS=1200
MORSE_HISTORY_MESSAGE_LIMIT=12
MORSE_RETRIEVAL_LIMIT=5

# Optional analytics only. Missing rates produce unknown cost, never a fake zero.
MORSE_INPUT_USD_PER_MILLION=
MORSE_OUTPUT_USD_PER_MILLION=

# Bocha is the only S10 search provider. Keep disabled until a key is configured.
MORSE_SEARCH_PROVIDER=bocha
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com/v1
MORSE_OFFICIAL_SOURCE_DOMAINS=openai.com,platform.openai.com
MORSE_OFFICIAL_GITHUB_OWNERS=Morse-Moss

# Private admin. Generate values locally; never commit real credentials.
MORSE_ADMIN_PASSWORD_HASH=
MORSE_ADMIN_TOTP_SECRET=
MORSE_ADMIN_COOKIE=morse_admin
MORSE_ADMIN_SESSION_MINUTES=30
MORSE_ADMIN_MAX_FAILED_ATTEMPTS=5
MORSE_ADMIN_LOCK_MINUTES=15
MORSE_ADMIN_ALLOWED_ORIGIN=http://127.0.0.1:3010

# Invite abuse controls.
MORSE_INVITE_FINGERPRINT_SECRET=
MORSE_INVITE_MAX_FAILED_ATTEMPTS=5
MORSE_INVITE_ATTEMPT_WINDOW_SECONDS=600
MORSE_INVITE_LOCK_SECONDS=900
# 0 ignores forwarding headers. Set only to the number of trusted proxies in front of the app.
MORSE_INVITE_TRUSTED_PROXY_HOPS=0

# Feishu alerts. Missing webhook keeps real delivery BLOCKED_EXTERNAL.
MORSE_ALERTS_ENABLED=false
FEISHU_WEBHOOK_URL=
MORSE_ALERT_DISPATCH_LIMIT=20
MORSE_ALERT_MAX_ATTEMPTS=5
MORSE_WORKER_POLL_MS=5000
MORSE_WORKER_BACKOFF_MAX_MS=60000
MORSE_CLEANUP_INTERVAL_MS=3600000
